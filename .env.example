PRIVATE_KEY=0x...          # Agent wallet private key
RPC_URL=https://forno.celo.org
TELEGRAM_BOT_TOKEN=        # From @BotFather

# Alert thresholds
LOW_CELO=0.5
LOW_CUSD=5
LARGE_TX_CELO=5
WATCH_INTERVAL_MS=30000

# Whale tracker
WHALE_CELO=50
WHALE_USD=500

# Price drop alert (% drop from reference to trigger — default 10%)
PRICE_DROP_PCT=10

# Email via SMTP app password (Gmail, Outlook, etc.)
# Gmail: enable 2FA → Google Account → Security → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=                 # 16-char app password (NOT your Gmail password)
EMAIL_FROM=Pulse <you@gmail.com>

# Self Protocol (needs public HTTPS URL)
WEBHOOK_URL=
WEBHOOK_PORT=3001
